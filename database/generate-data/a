function rowToInsert(table, row, columns) {
  const cols = columns || Object.keys(row);
  const values = cols.map((c) => {
    const v = row[c];
    if (v instanceof Date) return sqlTimestamp(v);
    if (typeof v === 'object' && v !== null && !(v instanceof Date) && !Buffer.isBuffer(v)) {
      // If this is already a JSON string for a text column, keep it as text.
      if (c === 'tags' || c === 'last_position') return sqlEscape(v);
      return sqlEscape(v);
    }
    if (typeof v === 'string' && ['created_at', 'updated_at', 'edited_at', 'start_time', 'end_time', 'resolved_at', 'expires_at', 'completed_at', 'viewed_at', 'viewed_hour', 'target_date', 'timestamp'].includes(c)) {
      return sqlEscape(v);
    }
    return sqlEscape(v);
  });
  return `INSERT INTO public.${table} (${cols.map((c) => `"${c}"`).join(', ')}) VALUES (${values.join(', ')});`;
}

function emitTable(tableName, rowsArray, columnOrder) {
  return rowsArray.map((r) => rowToInsert(tableName, r, columnOrder)).join('\n');
}

