async function callLlama(prompt, fallback) {
  try {
    const res = await fetch(`${LLAMA_BASE_URL}/v1/chat/completions`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: LLAMA_MODEL,
        messages: [
          { role: 'system', content: 'You write short, natural, realistic content for an English learning app. Return only the requested text.' },
          { role: 'user', content: prompt },
        ],
        temperature: 0.8,
        max_tokens: 180,
      }),
    });

    if (!res.ok) return fallback;
    const data = await res.json();
    const text = data?.choices?.[0]?.message?.content?.trim();
    if (!text) return fallback;
    return text.replace(/^"|"$/g, '');
  } catch {
    return fallback;
  }
}

