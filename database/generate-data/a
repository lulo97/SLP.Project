/**
 * Seed generator for the provided PostgreSQL schema.
 *
 * What this script does:
 * - Generates realistic, interrelated data for every table in the schema.
 * - Preserves JSON shapes for jsonb columns with deterministic structures.
 * - Writes a self-contained SQL file with INSERT statements wrapped in BEGIN/COMMIT.
 * - Optionally uses a local Llama server (OpenAI-compatible /v1/chat/completions) for richer text.
 *
 * How to use:
 *   1) Save as seed-all-tables.js
 *   2) node seed-all-tables.js
 *
 * Optional environment variables:
 *   LLAMA_BASE_URL=http://localhost:8080
 *   LLAMA_MODEL=llama
 *   OUT_FILE=seed.sql
 *   SEED=42
 *
 * Notes:
 * - This script does not require external npm packages.
 * - If your local Llama server uses a different endpoint, edit callLlama().
 * - Because no sample row examples were provided beyond the schema, JSON structures are inferred from column names and table relationships.
 */

const fs = require('fs');
const path = require('path');

const OUT_FILE = process.env.OUT_FILE || path.resolve(process.cwd(), 'seed.sql');
const LLAMA_BASE_URL = process.env.LLAMA_BASE_URL || 'http://localhost:8080';
const LLAMA_MODEL = process.env.LLAMA_MODEL || 'llama';
const SEED = Number(process.env.SEED || 42);

// -----------------------------
// Small deterministic RNG
// -----------------------------
function mulberry32(a) {
  return function () {
    let t = (a += 0x6D2B79F5);
    t = Math.imul(t ^ (t >>> 15), t | 1);
    t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const rand = mulberry32(SEED);
const rnd = (min, max) => Math.floor(rand() * (max - min + 1)) + min;
const pick = (arr) => arr[rnd(0, arr.length - 1)];
const sample = (arr, n) => {
  const copy = [...arr];
  const out = [];
  while (copy.length && out.length < n) {
    out.push(copy.splice(rnd(0, copy.length - 1), 1)[0]);
  }
  return out;
};
const shuffle = (arr) => {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = rnd(0, i);
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
};

function sqlEscape(value) {
  if (value === null || value === undefined) return 'NULL';
  if (typeof value === 'number') return Number.isFinite(value) ? String(value) : 'NULL';
  if (typeof value === 'boolean') return value ? 'TRUE' : 'FALSE';
  if (value instanceof Date) return `'${value.toISOString().replace('T', ' ').replace('Z', '+00')}'`;
  if (typeof value === 'object') {
    return `'${JSON.stringify(value).replace(/'/g, "''")}'::jsonb`;
  }
  const s = String(value)
    .replace(/\\/g, '\\\\')
    .replace(/'/g, "''");
  return `'${s}'`;
}

function sqlTimestamp(date) {
  return `'${date.toISOString().replace('T', ' ').replace('Z', '+00')}'`;
}

function sqlDate(date) {
  return `'${date.toISOString().slice(0, 10)}'`;
}

function makeDate(daysAgo = 0, hour = 12, minute = 0) {
  const d = new Date(Date.UTC(2026, 2, 19, hour, minute, 0));
  d.setUTCDate(d.getUTCDate() - daysAgo);
  return d;
}

