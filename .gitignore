# ==================================================
# Global .gitignore – .NET + Vite Vue TypeScript
# ==================================================

# --------------------
# OS files
# --------------------
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
.Spotlight-V100
.Trashes
._*

# --------------------
# Editor / IDE
# --------------------

# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
.history/

# JetBrains
.idea/
*.iml

# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Vim / Emacs
*.swp
*.swo
*~
.\#*

# --------------------
# Logs / temp
# --------------------
*.log
*.pid
*.seed
*.pid.lock
*.tmp
*.temp

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --------------------
# Environment / secrets
# --------------------
.env
.env.local
.env.*.local

*.pem
*.key
*.crt

# --------------------
# Node / Vite / Vue
# --------------------
node_modules/

# package manager caches
.pnpm-store/
.npm/
.yarn/
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# build outputs
dist/
.vite/
.cache/

# framework caches
.nuxt/
.output/
.svelte-kit/

# TypeScript
*.tsbuildinfo

# --------------------
# .NET / C#
# --------------------

# Build results
bin/
obj/

# Rider
.idea/.idea.*

# ASP.NET publish
publish/

# Test results
TestResults/
*.trx

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/

# Generated files
Generated_Code/

# --------------------
# Coverage
# --------------------
coverage/
*.coverage
*.coveragexml

# --------------------
# Misc
# --------------------
*.orig
*.rej
*.patch
*.diff

slp/backend-dotnet/logs

view_features.txt

*.gguf

*.onnx
*.onnx.json

__pycache__

project-structure.txt

venv

uploads