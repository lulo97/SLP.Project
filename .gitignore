# ==================================================
# Global .gitignore – cross‑project patterns
# ==================================================

# --------------------
# Operating system files
# --------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# --------------------
# Editor / IDE files
# --------------------

## Vim
*.swp
*.swo
*~
[._]*.un~

## Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

## Sublime Text
*.sublime-project
*.sublime-workspace
*.sublime-*

## Visual Studio Code
.vscode/
!.vscode/settings.json  # uncomment if you want to keep workspace settings
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

## JetBrains (IntelliJ, PyCharm, etc.)
.idea/
*.iml
*.iws
out/
.idea_modules/
atlassian-ide-plugin.xml
com_crashlytics_export_strings.xml
crashlytics-build.properties
fabric.properties

## Eclipse
.project
.classpath
.settings/
.metadata/
bin/
tmp/
*.tmp
*.bak
*.swp
*.swo
*~
.idea/
*.iml
*.iws

## NetBeans
nbproject/private/
nbbuild/
dist/
nbdist/
nbactions.xml
nb-configuration.xml

## Xcode
xcuserdata/
*.xcuserstate
*.xcbkptlist
*.xcworkspace
!default.xcworkspace
*.mode1v3
*.mode2v3
*.perspectivev3
!default.perspectivev3
DerivedData/
*.moved-aside
*.pbxuser
!default.pbxuser
*.perspectivev3
!default.perspectivev3

# --------------------
# Logs, databases, and temporary files
# --------------------
*.log
*.sql
*.sqlite
*.db
*.dump
*.pid
*.seed
*.pid.lock
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
*.tmp
*.temp
*.cache

# --------------------
# Environment and secrets
# --------------------
.env
.env.local
.env.*.local
.flaskenv
.venv
venv/
ENV/
env/
env.bak/
venv.bak/
*.pem
*.key
*.crt

# --------------------
# Package manager caches / lock files (usually better kept in repo)
# --------------------
# These are often intentionally committed; adjust as needed.
# npm / yarn
package-lock.json
yarn.lock
# pip
Pipfile.lock
# conda
environment.yml.lock
# composer
composer.lock
# gem
Gemfile.lock

# --------------------
# Compiled output
# --------------------
*.pyc
*.pyo
__pycache__/
*.class
*.exe
*.dll
*.so
*.dylib
*.o
*.obj
*.lib
*.a
*.out
*.app

# --------------------
# Coverage and testing
# --------------------
.coverage
.nyc_output/
coverage/
*.cover
.hypothesis/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --------------------
# Documentation and build
# --------------------
_site/
.sass-cache/
.jekyll-cache/
.jekyll-metadata
docs/_build/
target/
build/
dist/
*.egg-info/

# --------------------
# Miscellaneous
# --------------------
*.orig
*.rej
*.patch
*.diff
*_flymake.*
*.log
*.err
.DS_Store
.Trashes